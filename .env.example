# Anthropic — API key and model for chat agents
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL_ID=claude-sonnet-4-6

# Azure OpenAI — used for embeddings only (chat uses Anthropic)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Search — endpoint for your search service
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
# Name of the search index used for RAG retrieval
AZURE_SEARCH_INDEX_NAME=surf-index
# SharePoint search index (set after running setup-indexer)
AZURE_SEARCH_SHAREPOINT_INDEX=surf-sharepoint-index

# Azure Cosmos DB — endpoint for conversation persistence
COSMOS_ENDPOINT=https://<your-resource>.documents.azure.com:443/
# Database name (default: surf)
COSMOS_DATABASE_NAME=surf
# Container name for storing conversation history
COSMOS_CONTAINER_NAME=conversations

# Azure Storage — blob endpoint for document storage (ingestion pipeline)
AZURE_STORAGE_ACCOUNT_URL=https://<your-resource>.blob.core.windows.net

# Auth — Entra ID SSO (leave empty to disable auth in dev)
AUTH_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# SharePoint sync — credentials and site config for ingestion pipeline
SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site-name>
SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
# Document library name (omit to use default library)
# SHAREPOINT_LIBRARY_NAME=Documents
# Subfolder path within the library (omit to sync entire library)
# SHAREPOINT_FOLDER_PATH=
# Sync site pages as HTML (default: true)
# SHAREPOINT_SYNC_PAGES=true
# Metadata tags applied to synced documents
# SHAREPOINT_DOMAIN=hr
# SHAREPOINT_DOCUMENT_TYPE=policy

# Application settings
ENVIRONMENT=dev  # dev | staging | prod
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
