# Azure OpenAI — endpoint for your Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# Deployment name for the chat model (default: gpt-5.2-chat)
AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=gpt-5.2-chat
# Azure OpenAI API version
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Azure AI Search — endpoint for your search service
AZURE_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
# Name of the search index used for RAG retrieval
AZURE_SEARCH_INDEX_NAME=surf-index

# Azure Cosmos DB — endpoint for conversation persistence
COSMOS_ENDPOINT=https://<your-resource>.documents.azure.com:443/
# Database name (default: surf)
COSMOS_DATABASE_NAME=surf
# Container name for storing conversation history
COSMOS_CONTAINER_NAME=conversations

# Azure Storage — blob endpoint for document storage (ingestion pipeline)
AZURE_STORAGE_ACCOUNT_URL=https://<your-resource>.blob.core.windows.net

# Application settings
ENVIRONMENT=dev  # dev | staging | prod
LOG_LEVEL=INFO   # DEBUG | INFO | WARNING | ERROR
