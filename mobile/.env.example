# API connection
# For iOS Simulator: localhost works
# For physical device: use your dev machine's network IP (e.g. http://192.168.1.100:8090/api/v1)
EXPO_PUBLIC_API_URL=http://localhost:8090/api/v1

# Entra ID authentication (optional — leave blank to disable auth)
EXPO_PUBLIC_ENTRA_CLIENT_ID=
EXPO_PUBLIC_ENTRA_TENANT_ID=
