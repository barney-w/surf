# SharePoint Sync Configuration
# Copy to .env and fill in values from your Azure deployment

# IMPORTANT: Only sync from libraries containing content appropriate for
# all chatbot users. Documents with restricted SharePoint permissions are
# NOT filtered — they will be indexed and visible to everyone.

# Entra app registration (registered in your tenant)
# For production, use Sites.Selected permission instead of Sites.Read.All
# to scope access to only the configured site.
SHAREPOINT_CLIENT_ID=<your-entra-app-client-id>
SHAREPOINT_CLIENT_SECRET=<your-client-secret>
SHAREPOINT_TENANT_ID=<your-tenant-id>

# Target SharePoint site (the site you want to index)
SHAREPOINT_SITE_URL=https://<tenant>.sharepoint.com/sites/<site-name>

# Optional: specific library and folder path within the site
# Leave empty to index the default document library root
SHAREPOINT_LIBRARY_NAME=
SHAREPOINT_FOLDER_PATH=

# Content classification (used for search filtering in the API)
SHAREPOINT_DOMAIN=hr
SHAREPOINT_DOCUMENT_TYPE=policy

# Azure Storage (where synced files land — already deployed by Bicep)
AZURE_STORAGE_ACCOUNT_URL=https://<your-storage>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=documents
AZURE_STORAGE_BLOB_PREFIX=sharepoint/

# Azure AI Search (where the indexer pipeline runs — already deployed by Bicep)
AZURE_SEARCH_ENDPOINT=https://<your-search>.search.windows.net
AZURE_SEARCH_INDEX_NAME=surf-sharepoint-index

# Azure subscription (used by setup_sharepoint_indexer.py)
# If not set, falls back to az CLI for local development
AZURE_SUBSCRIPTION_ID=

# Sync behaviour
SHAREPOINT_SYNC_PAGES=true
SHAREPOINT_SKIP_DELETION_RECONCILIATION=false
SHAREPOINT_MAX_FILE_SIZE_MB=100
SHAREPOINT_MAX_CONCURRENT_REQUESTS=10
SHAREPOINT_MAX_RETRIES=5
SHAREPOINT_TIMEOUT_SECONDS=60
SHAREPOINT_DOWNLOAD_TIMEOUT_SECONDS=300

# Sensitivity label filtering (optional)
# Set to skip files with labels above this threshold:
#   general, internal, confidential, highly_confidential
# Leave empty to sync all files regardless of sensitivity label.
SHAREPOINT_SENSITIVITY_LABEL_THRESHOLD=
