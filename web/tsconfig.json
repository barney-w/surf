{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "outDir": "dist",
    "paths": {
      "@surf-kit/agent": ["../../surf-kit/packages/agent/src/index.ts"],
      "@surf-kit/agent/*": ["../../surf-kit/packages/agent/src/*/index.ts", "../../surf-kit/packages/agent/src/*.ts"]
    }
  },
  "include": ["src"]
}
